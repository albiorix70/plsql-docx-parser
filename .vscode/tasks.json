{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile docx_parser (Bash)",
      "type": "shell",
      "command": "bash",
      "args": ["-lc", "./ci/run_compile.sh"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Compile docx_parser (PowerShell)",
      "type": "shell",
      "command": "powershell",
      "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}\\ci\\run_compile.ps1"],
      "windows": {
        "command": "powershell",
        "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}\\ci\\run_compile.ps1"]
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
    ,
    {
      "label": "Compile with MCP/CLI (Bash)",
      "type": "shell",
      "command": "bash",
      "args": ["-lc", "./ci/run_mcp_cli.sh"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Compile with MCP/CLI (PowerShell)",
      "type": "shell",
      "command": "powershell",
      "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}\\ci\\run_mcp_cli.ps1"],
      "windows": {
        "command": "powershell",
        "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}\\ci\\run_mcp_cli.ps1"]
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
